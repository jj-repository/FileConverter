{
  "name": "fileconverter",
  "private": true,
  "version": "1.16.0",
  "description": "Desktop file conversion application",
  "main": "electron/main.cjs",
  "type": "module",
  "homepage": "https://github.com/jj-repository/FileConverter",
  "repository": {
    "type": "git",
    "url": "https://github.com/jj-repository/FileConverter.git"
  },
  "bugs": {
    "url": "https://github.com/jj-repository/FileConverter/issues"
  },
  "author": {
    "name": "FileConverter",
    "email": "fileconverter@users.noreply.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "i18next": "^25.8.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^16.5.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.fileconverter.app",
    "productName": "FileConverter",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "../backend/**/*",
      "!../backend/venv/**/*",
      "!../backend/**/__pycache__/**/*",
      "!../backend/**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!venv/**/*",
          "!**/__pycache__/**/*",
          "!**/*.pyc",
          "!**/.env*",
          "!build/**/*",
          "!*.spec",
          "!run_server.py"
        ]
      },
      {
        "from": "../resources/bin/${os}",
        "to": "resources/bin/${os}",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "FileConverter-Setup.${ext}"
    },
    "portable": {
      "artifactName": "FileConverter.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "FileConverter <fileconverter@users.noreply.github.com>",
      "artifactName": "FileConverter-Linux.${ext}"
    },
    "deb": {
      "artifactName": "FileConverter-Linux.${ext}"
    }
  }
}
